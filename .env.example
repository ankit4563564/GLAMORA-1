# Clerk (required for sign-in; without these the site still loads in demo mode)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Optional demo one-click sign-in (Clerk dashboard user)
NEXT_PUBLIC_DEMO_USER_EMAIL=demo@glamora.in
NEXT_PUBLIC_DEMO_USER_PASSWORD=Demo@2026

# MongoDB
MONGODB_URI=mongodb+srv://...

# Google Gemini
GEMINI_API_KEY=...
# Agent: local search is default (fast). Set AGENT_USE_LLM=true for long ambiguous queries only.
# AGENT_USE_LLM=false
# GEMINI_AGENT_MODEL=gemini-1.5-flash

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
