# Clerk (required for sign-in; without these the site still loads in demo mode)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Optional demo one-click sign-in (Clerk dashboard user)
NEXT_PUBLIC_DEMO_USER_EMAIL=demo@glamora.in
NEXT_PUBLIC_DEMO_USER_PASSWORD=Demo@2026

# MongoDB
MONGODB_URI=mongodb+srv://...

# Groq (recommended for AI Agent + marketing — fast, get key at https://console.groq.com)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (BeautyAI vision; fallback text if Groq is not set)
GEMINI_API_KEY=...
# GEMINI_VISION_MODEL=gemini-1.5-flash
# GEMINI_AGENT_MODEL=gemini-1.5-flash

# Agent: local search by default. Set AGENT_USE_LLM=false to disable all LLM calls.
# AGENT_USE_LLM=false

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
